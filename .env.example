# Telegram bot token — get it from @BotFather (/newbot)
TELEGRAM_BOT_TOKEN=

# Only messages from this Telegram user id are served (ask @userinfobot for your id)
OWNER_USER_ID=

# (optional) allowed group chat ids, comma-separated (usually negative). Empty = only your DMs.
# In a group, only @bot mentions or replies to it trigger a turn. **Go to @BotFather /setprivacy
# and select this bot → Disable first** — with privacy mode ON (the default), a plain-text
# @mention never even reaches the bot (only commands and replies do); if you already added the
# bot to a group, remove and re-add it for this to take effect. To get an id: add the bot to
# the group, @-mention it once — it replies with that group's id — then fill it in here. Anyone
# in the group can drive this agent, so only add groups you trust.
ALLOWED_GROUP_IDS=

# Claude Code headless auth — generate on a machine with a browser via `claude setup-token`
# (sk-ant-oat01-…, ~1 year validity; an interactive login token doesn't auto-refresh headlessly, don't use that)
CLAUDE_CODE_OAUTH_TOKEN=

# Display name (optional, defaults to Agent)
AGENT_NAME=Agent

# claude CLI path (optional, defaults to ~/.local/bin/claude)
# CLAUDE_BIN=/home/user/.local/bin/claude

# Max seconds per conversation turn (optional, defaults to 1800)
# AGENT_TURN_TIMEOUT=1800

# (optional) only needed if the bot runs as root (e.g. a bare LXC container): claude refuses
# bypassPermissions under root, set IS_SANDBOX=1 to allow it inside a sandboxed container.
# Not needed if running as a non-root user.
# IS_SANDBOX=1
