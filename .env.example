# Telegram bot token — 跟 @BotFather 要(/newbot)
TELEGRAM_BOT_TOKEN=

# 只有這個 Telegram user id 的訊息會被服務(問 @userinfobot 拿你的 id)
OWNER_USER_ID=

# Claude Code headless auth — 在有瀏覽器的機器跑 `claude setup-token` 產生
# (sk-ant-oat01-…,效期 1 年;互動 login token 在 headless 下不會自動 refresh,別用)
CLAUDE_CODE_OAUTH_TOKEN=

# 顯示名(選填,預設 Agent)
AGENT_NAME=Agent

# claude CLI 路徑(選填,預設 ~/.local/bin/claude)
# CLAUDE_BIN=/home/user/.local/bin/claude

# 一次對話最長秒數(選填,預設 1800)
# AGENT_TURN_TIMEOUT=1800
