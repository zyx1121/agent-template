# Telegram bot token — 跟 @BotFather 要(/newbot)
TELEGRAM_BOT_TOKEN=

# 只有這個 Telegram user id 的訊息會被服務(問 @userinfobot 拿你的 id)
OWNER_USER_ID=

# (選填)允許使用的群組 chat id,逗號分隔(通常是負數)。留空 = 只服務你的私訊。
# 群組內只有 @bot 或 reply 它的訊息才會觸發。拿 id:把 bot 加進群、在群裡 @它 一句,
# 它會回覆這個群的 id,填進來再 restart。群組成員都能驅動這個 agent,只加信任的群。
ALLOWED_GROUP_IDS=

# Claude Code headless auth — 在有瀏覽器的機器跑 `claude setup-token` 產生
# (sk-ant-oat01-…,效期 1 年;互動 login token 在 headless 下不會自動 refresh,別用)
CLAUDE_CODE_OAUTH_TOKEN=

# 顯示名(選填,預設 Agent)
AGENT_NAME=Agent

# claude CLI 路徑(選填,預設 ~/.local/bin/claude)
# CLAUDE_BIN=/home/user/.local/bin/claude

# 一次對話最長秒數(選填,預設 1800)
# AGENT_TURN_TIMEOUT=1800

# (選填)只有 bot 以 root 跑(例如裸 LXC container)才需要:claude 拒絕 root 下的
# bypassPermissions,設 IS_SANDBOX=1 允許在 sandbox 容器內跑。用非 root user 就不用這個。
# IS_SANDBOX=1
